%% MouseReach segmenter decision tree
%% Algorithm: multi_proposer_sabl_primary_v1
%% Version: 2.2.0
%% Last updated: 2026-04-24
%%
%% Legend for threshold annotations:
%%   [T]  = tunable threshold (current value in label; principled to sweep)
%%   [F]  = feature-definition-limited (changing it means redefining the
%%          underlying feature, not just nudging a number)
%%   [S]  = structural constant (physics of the apparatus)
%%
%% Inputs at top, outputs at bottom. Subgraphs correspond to code phases.
%% v2.1.3 diagram preserved in git history at commit 8e43976.

flowchart TB
    h5["INPUT: DLC h5<br/>per-frame (x, y, likelihood) for<br/>SABL, SABR, SATL, SATR,<br/>BOXL, BOXR, Pellet, Hand, Nose, Pillar"]

    subgraph Q["Phase 1 -- Reference & SA coverage quality (unchanged from v2.1.3)"]
        refq{"assess_reference_quality<br/>BOXL, BOXR should be stationary<br/>[T] std < 5 px  -> good<br/>[T] std < 15 px -> suspect<br/>else            -> bad<br/>box_center = median(BOXL_x, BOXR_x)"}
        sacov{"assess_sa_quality<br/>coverage[bp] = mean(likelihood > 0.5)<br/>for SABL, SABR, SATL, SATR"}
    end

    h5 --> refq
    h5 --> sacov

    subgraph P2["Phase 2 -- Four SA corner proposers (each runs independently)"]
        direction TB

        subgraph P2A["SABL proposer (frame source, aligned with GT)"]
            sabl_clean["get_clean_signal(SABL_x):<br/>fill likelihood < 0.5 forward,<br/>median filter (window=5)"]
            sabl_deriv["sabl_rel = SABL_x - box_center<br/>velocity = smoothed |d SABL_x|<br/>[T] smooth_window = 30 frames"]
            sabl_cross{"Pass 1: centered crossings<br/>[T] -5 < rel < 10 (px)<br/>[T] velocity > 0.8 (px/frame)<br/>[T] min_gap = 25 frames<br/>[F] center_target = 2.5 px"}
            sabl_rescue{"Pass 2: endpoint rescue<br/>(if >= 15 primary candidates)<br/>velocity-only peaks before first /<br/>after last primary candidate<br/>[T] endpoint_vel > 1.4 (px/frame)<br/>catches B1/B21 where position<br/>drifted past centered window"}
            sabl_clean --> sabl_deriv --> sabl_cross --> sabl_rescue
        end

        subgraph P2B["SATL proposer (frame source, aligned with GT)"]
            satl_proc["Same centered-crossing +<br/>endpoint rescue logic as SABL<br/>applied to SATL_x signal"]
        end

        subgraph P2C["SABR proposer (confirmer only -- ~7f early bias vs GT)"]
            sabr_proc["Same logic applied to SABR_x<br/>Votes for consensus but<br/>NEVER sets the final frame<br/>[S] ~7f early bias = physical<br/>property of tray corner geometry"]
        end

        subgraph P2D["SATR proposer (confirmer only -- ~7f early bias vs GT)"]
            satr_proc["Same logic applied to SATR_x<br/>Votes for consensus but<br/>NEVER sets the final frame<br/>[S] ~7f early bias = physical<br/>property of tray corner geometry"]
        end
    end

    refq -- "quality != 'bad'" --> sabl_clean
    refq -- "quality != 'bad'" --> satl_proc
    refq -- "quality != 'bad'" --> sabr_proc
    refq -- "quality != 'bad'" --> satr_proc

    subgraph P25["Phase 2.5 -- Consensus merging"]
        cluster{"cluster_candidates<br/>Single-linkage clustering<br/>all candidates by frame proximity<br/>[T] merge_window = 30 frames"}
        merge["merge_cluster (per cluster):<br/>frame = SABL or SATL candidate<br/>(whichever has higher confidence)<br/>SABR/SATR vote only (never set frame)<br/>[S] reason: 7f early bias"]
        cscore["consensus_score = f(n_proposers, avg_conf)<br/>4 proposers: avg_conf * 1.5<br/>3 proposers: avg_conf * 1.3<br/>2 proposers: avg_conf * 1.1<br/>1 proposer:  avg_conf * 0.9"]
    end

    sabl_rescue --> cluster
    satl_proc --> cluster
    sabr_proc --> cluster
    satr_proc --> cluster
    cluster --> merge --> cscore

    subgraph P26["Phase 2.6 -- Hybrid mode decision"]
        hybrid{"SABL alone produced<br/>exactly 21 candidates?<br/>(43/47 videos in corpus)"}
        sabl_primary["SABL-primary mode:<br/>Use 21 SABL frames as backbone.<br/>For each, find closest merged<br/>candidate within merge_window.<br/>Usually keeps SABL's frame<br/>(consensus refines only)."]
        full_consensus["Full consensus mode:<br/>(4/47 videos where SABL != 21)<br/>Run select_boundaries on<br/>merged candidates with same<br/>downstream routing as v2.1.3"]
    end

    cscore --> hybrid
    hybrid -- "Yes (SABL == 21)" --> sabl_primary
    hybrid -- "No (SABL != 21)" --> full_consensus

    subgraph P3["Phase 3 -- Boundary selection (inherited from v2.1.3)"]
        select{"select_boundaries<br/>How many merged candidates?"}
        s_n0["N = 0: evenly-spaced<br/>[S] 21-point fallback"]
        s_n21["N = 21: accept as-is"]
        s_close{"17 <= N <= 25?"}
        s_drop["N > 21: drop lowest by<br/>(n_proposers, consensus_score)"]
        s_fill["N < 21: project endpoints<br/>or interpolate largest gaps"]
        s_grid["Else: build grid from<br/>estimated B1 + i * actual_interval<br/>[T] expected_interval = 1839 frames"]
    end

    full_consensus --> select
    select -- "N=0" --> s_n0
    select -- "N=21" --> s_n21
    select -- "near 21" --> s_close
    select -- "else" --> s_grid
    s_close -- "too many" --> s_drop
    s_close -- "too few" --> s_fill

    subgraph P4["Phase 4 -- Validate & correct (inherited from v2.1.3)"]
        phantom{"Phantom internal-boundary test<br/>Adjacent interval pair (a, b):<br/>[T] a < 0.95 * median<br/>[T] b < 0.95 * median<br/>[T] |a+b - median| < 0.15 * median<br/>[T] |before - median| < 0.15 * median<br/>[T] |after  - median| < 0.15 * median"}
        remove["Drop boundary. Re-derive<br/>intervals and median. Iterate."]
        endproj{"Endpoint projection<br/>len(frames) < 21 AND<br/>[T] gap_to_start > 0.9 * median<br/>  or gap_to_end > 0.9 * median?"}
        projb1["Insert B1:<br/>max(0, frames[0] - median)"]
        projb21["Append B21:<br/>min(total_frames-1, frames[-1] + median)"]
    end

    sabl_primary --> phantom
    s_n0 --> phantom
    s_n21 --> phantom
    s_drop --> phantom
    s_fill --> phantom
    s_grid --> phantom
    phantom -- "pair matches" --> remove
    remove --> phantom
    phantom -- "no pair matches" --> endproj
    endproj -- "gap_to_start large" --> projb1
    endproj -- "gap_to_end large" --> projb21
    projb1 --> endproj
    projb21 --> endproj

    subgraph P5["Phase 5 -- Anomaly detection & emit (inherited from v2.1.3)"]
        anomd["detect_anomalies:<br/>flag interval CV outliers,<br/>duplicates, out-of-order,<br/>[S] any interval < 300 f (5 s)<br/>[S] any interval > 1200 f (20 s)"]
        emit["OUTPUT _segments.json:<br/>boundaries (21 ints)<br/>per-boundary method (proposer combo)<br/>per-boundary consensus_score<br/>overall_confidence, reference_quality<br/>sa_coverage, anomalies list<br/>interval_mean/std/cv<br/>segmenter_version = 2.2.0<br/>segmenter_algorithm = multi_proposer_sabl_primary_v1"]
    end

    endproj -- "no more projection" --> anomd
    anomd --> emit

    refq -- "quality == 'bad'" --> fallback_evenly
    fallback_evenly["Bad reference: evenly-spaced<br/>[S] 21-point fallback<br/>(every total_frames / 22)"] --> anomd
