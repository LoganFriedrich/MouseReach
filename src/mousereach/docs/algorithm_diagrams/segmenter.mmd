%% MouseReach segmenter decision tree
%% Algorithm: sabl_centered_crossing_v2
%% Version: 2.1.3
%% Last updated: 2026-04-23
%%
%% Legend for threshold annotations:
%%   [T]  = tunable threshold (current value in label; principled to sweep)
%%   [F]  = feature-definition-limited (changing it means redefining the
%%          underlying feature, not just nudging a number)
%%   [S]  = structural constant (physics of the apparatus)
%%
%% Inputs at top, outputs at bottom. Subgraphs correspond to code phases.

flowchart TB
    h5["INPUT: DLC h5<br/>per-frame (x, y, likelihood) for<br/>SABL, SABR, SATL, SATR,<br/>BOXL, BOXR, Pellet, Hand, Nose, Pillar"]

    subgraph Q["Phase 1 - Reference &amp; SA coverage quality"]
        refq{"assess_reference_quality<br/>BOXL, BOXR are supposed to be stationary<br/>[T] std &lt; 5 px  -&gt; good<br/>[T] std &lt; 15 px -&gt; suspect<br/>else            -&gt; bad<br/>box_center = median(BOXL_x, BOXR_x)"}
        sacov{"assess_sa_quality<br/>coverage[bp] = mean(likelihood &gt; 0.5)<br/>for SABL, SABR, SATL, SATR"}
    end

    h5 --> refq
    h5 --> sacov

    subgraph P["Phase 2 - Primary: SABL centered-crossing"]
        clean["get_clean_signal(SABL_x):<br/>fill frames with likelihood &lt; 0.5 forward,<br/>then median filter (window=5 frames)"]
        deriv["sabl_rel = SABL_x - box_center<br/>velocity = smoothed |d SABL_x|<br/>(uniform filter, window=30 frames)"]
        cross{"find_centered_crossings<br/>centered AND moving?<br/>[T] -5 &lt; sabl_rel &lt; 10 (px rel box_center)<br/>[T] velocity &gt; 1.2 (px/frame)<br/>[T] min_gap = 30 frames between events"}
        retry{"Found at least 21 candidates?"}
        retry_lo["Retry with<br/>[T] velocity &gt; 0.8"]
        score["Per event:<br/>best_frame maximizes -abs(sabl_rel - 2.5) + 2*velocity<br/>[F] center target 2.5 px (just past box center)"]
        validate["validate_with_other_sa_points:<br/>for SABR, SATL, SATR: is max(velocity) &gt; 1.0<br/>in +/- 30-frame window around candidate?<br/>agreement_rate blends into confidence"]
    end

    refq -- "quality != 'bad'" --> clean
    clean --> deriv
    deriv --> cross
    cross --> retry
    retry -- "No" --> retry_lo
    retry -- "Yes" --> score
    retry_lo --> score
    score --> validate

    subgraph F["Phase 2b - Fallback: aggregate motion peaks"]
        fallb{"Primary yielded fewer than 10 candidates?"}
        peaks["find_motion_peaks:<br/>scipy find_peaks on velocity signal<br/>[T] distance = 20 s (1200 frames at 60 fps)<br/>[T] prominence = 85th percentile of velocity<br/>applied to first SA with signal; stop at 15+ peaks"]
    end

    validate --> fallb
    refq -- "quality == 'bad'" --> fallb
    fallb -- "Yes" --> peaks
    fallb -- "No, use primary" --> fit
    peaks --> fit

    subgraph G["Phase 3 - fit_grid_to_candidates"]
        fit{"How many candidates?"}
        n0["N = 0<br/>Evenly-spaced 21-point fallback<br/>(every total_frames/22)"]
        n21["N = 21<br/>Accept candidates as-is<br/>(best case)"]
        nclose{"19 &lt;= N &lt;= 23?"}
        drop["N &gt; 21:<br/>drop (N - 21) lowest-confidence candidates"]
        fill{"N &lt; 21:<br/>gap_to_end &gt; max_internal_gap * 0.8<br/>AND missing == 1?"}
        projb21_old["B21 projection:<br/>append frames[-1] + actual_interval<br/>(capped at total_frames - 1)"]
        interp["Interpolate midpoint of largest<br/>(21 - N) internal gaps"]
        grid["Else (N &lt; 19 or N &gt; 23):<br/>build grid from estimated B1<br/>+ i * actual_interval for i in 0..20<br/>where actual_interval = median of<br/>filtered inter-candidate intervals<br/>(0.5x to 1.5x of expected 1839)"]
    end

    fit -- "N=0" --> n0
    fit -- "N=21" --> n21
    fit -- "19..23" --> nclose
    fit -- "else" --> grid
    nclose -- "too many" --> drop
    nclose -- "too few" --> fill
    fill -- "Yes" --> projb21_old
    fill -- "No" --> interp

    subgraph V["Phase 4 - _validate_and_correct_boundaries  (v2.1.3)"]
        phantom{"Phantom internal-boundary test<br/>For each adjacent interval pair at index (i, i+1):<br/>[T] a &lt; 0.95 * median<br/>[T] b &lt; 0.95 * median<br/>[T] |a+b - median| &lt; 0.15 * median<br/>[T] |before - median| &lt; 0.15 * median   (bracket)<br/>[T] |after  - median| &lt; 0.15 * median   (bracket)"}
        remove["Drop boundary at index (i+1).<br/>Re-derive intervals and median.<br/>Iterate until no pair passes the test."]
        endproj{"Endpoint projection<br/>len(frames) &lt; 21 AND<br/>[T] gap_to_start &gt; 0.9 * median<br/>  or gap_to_end   &gt; 0.9 * median ?"}
        projb1["Project missing B1:<br/>insert max(0, frames[0] - median)"]
        projb21["Project missing B21:<br/>append min(total_frames-1, frames[-1] + median)"]
    end

    n0 --> phantom
    n21 --> phantom
    drop --> phantom
    projb21_old --> phantom
    interp --> phantom
    grid --> phantom
    phantom -- "pair matches" --> remove
    remove --> phantom
    phantom -- "no pair matches" --> endproj
    endproj -- "gap_to_start large" --> projb1
    endproj -- "gap_to_end large" --> projb21
    projb1 --> endproj
    projb21 --> endproj

    subgraph A["Phase 5 - anomaly detection &amp; emit"]
        anomd["detect_anomalies:<br/>flag if intervals std / mean (CV)<br/>exceeds thresholds;<br/>flag duplicates, out-of-order;<br/>flag [S] any interval &lt; 300 f (5 s)<br/>or [S] &gt; 1200 f (20 s)"]
        emit["OUTPUT _segments.json:<br/>boundaries (list of 21 ints)<br/>overall_confidence (0-1)<br/>reference_quality, sa_coverage<br/>per-boundary method &amp; confidence<br/>anomalies list<br/>interval_mean, interval_std, interval_cv<br/>segmenter_version, segmenter_algorithm"]
    end

    endproj -- "no more projection" --> anomd
    anomd --> emit
