digraph segmenter {
    graph [rankdir=TB, nodesep=0.35, ranksep=0.55, splines=polyline, fontname="Helvetica", bgcolor="white"];
    node  [fontname="Helvetica", fontsize=11, shape=box, style="rounded,filled", margin="0.15,0.08"];
    edge  [fontname="Helvetica", fontsize=9, color="#555555"];

    // Colors: inputs/outputs, checks, actions, each phase
    // Phase 1 quality      = light blue
    // Phase 2 primary      = light green
    // Phase 2b fallback    = light orange
    // Phase 3 fit grid     = light yellow
    // Phase 4 validate     = light purple
    // Phase 5 emit         = light grey

    // ===== INPUT =====
    h5 [label="INPUT\nDLC h5 file\nper-frame (x, y, likelihood) for\nSABL, SABR, SATL, SATR,\nBOXL, BOXR, Pellet, Hand, Nose, Pillar",
        shape=folder, fillcolor="#FFF2CC"];

    // ===== PHASE 1 =====
    refq [label="Phase 1a - assess_reference_quality\nBOXL, BOXR should be stationary\nstd < 5 px  -> good\nstd < 15 px -> suspect\nelse        -> bad\nbox_center = median(BOXL_x, BOXR_x)",
          shape=diamond, fillcolor="#DEEBF7"];
    sacov [label="Phase 1b - assess_sa_quality\ncoverage[bp] = mean(likelihood > 0.5)\nfor SABL, SABR, SATL, SATR",
           fillcolor="#DEEBF7"];

    // ===== PHASE 2 =====
    clean [label="get_clean_signal(SABL_x)\nforward-fill gaps where likelihood < 0.5\nthen median filter (window = 5 frames)",
           fillcolor="#E2F0D9"];
    deriv [label="sabl_rel = SABL_x - box_center\nvelocity = smoothed |d SABL_x|\n(uniform filter, window = 30 frames)",
           fillcolor="#E2F0D9"];
    cross [label="find_centered_crossings\ncentered AND moving?\n-5 < sabl_rel < 10 (px)\nvelocity > 1.2 (px/frame)\nmin_gap between events = 30 frames",
           shape=diamond, fillcolor="#E2F0D9"];
    retry [label="Got at least\n21 candidates?",
           shape=diamond, fillcolor="#E2F0D9"];
    retry_lo [label="Retry with\nvelocity > 0.8",
              fillcolor="#E2F0D9"];
    score [label="Per event:\nbest_frame maximizes\n-|sabl_rel - 2.5| + 2 * velocity",
           fillcolor="#E2F0D9"];
    validate [label="validate_with_other_sa_points\nfor SABR, SATL, SATR:\nmax(velocity) > 1.0 within +/- 30 frames?\nagreement_rate blends into confidence",
              fillcolor="#E2F0D9"];

    // ===== PHASE 2b =====
    fallb [label="Primary produced\nfewer than 10 candidates?",
           shape=diamond, fillcolor="#FFE699"];
    peaks [label="find_motion_peaks\nscipy find_peaks on velocity\ndistance = 20 s (1200 frames)\nprominence = 85th percentile\nstops at 15+ peaks",
           fillcolor="#FFE699"];

    // ===== PHASE 3 =====
    fit [label="fit_grid_to_candidates\nHow many candidates?",
         shape=diamond, fillcolor="#FFF2CC"];
    n0 [label="N = 0\nEvenly-spaced 21-point fallback\n(every total_frames / 22)",
        fillcolor="#FFF2CC"];
    n21 [label="N = 21\nAccept candidates as-is\n(best case)",
         fillcolor="#FFF2CC"];
    nclose [label="19 <= N <= 23?",
            shape=diamond, fillcolor="#FFF2CC"];
    drop [label="N > 21\nDrop (N - 21) lowest-confidence",
          fillcolor="#FFF2CC"];
    fill [label="N < 21\ngap_to_end > max_internal_gap * 0.8\nAND missing == 1?",
          shape=diamond, fillcolor="#FFF2CC"];
    projb21_old [label="B21 projection\nappend frames[-1] + actual_interval\n(capped at total_frames - 1)",
                 fillcolor="#FFF2CC"];
    interp [label="Interpolate midpoint\nof largest (21 - N) internal gaps",
            fillcolor="#FFF2CC"];
    grid [label="Else (N < 19 or N > 23)\nBuild grid from estimated B1\n+ i * actual_interval for i in 0..20\nactual_interval = median of filtered\ninter-candidate intervals (0.5x-1.5x * 1839)",
          fillcolor="#FFF2CC"];

    // ===== PHASE 4 =====
    phantom [label="_validate_and_correct_boundaries (v2.1.3)\nPhantom internal-boundary test\nfor adjacent interval pair (a, b) at (i, i+1):\n  a < 0.95 * median\n  b < 0.95 * median\n  |a+b - median| < 0.15 * median\n  |before - median| < 0.15 * median\n  |after  - median| < 0.15 * median",
             shape=diamond, fillcolor="#E4DFEC"];
    remove [label="Drop boundary at (i+1).\nRe-derive intervals and median.\nRepeat until no pair matches.",
            fillcolor="#E4DFEC"];
    endproj [label="Endpoint projection\nlen(frames) < 21 AND\ngap_to_start > 0.9 * median\n  OR gap_to_end > 0.9 * median ?",
             shape=diamond, fillcolor="#E4DFEC"];
    projb1 [label="Insert B1:\nmax(0, frames[0] - median)",
            fillcolor="#E4DFEC"];
    projb21 [label="Append B21:\nmin(total_frames-1, frames[-1] + median)",
             fillcolor="#E4DFEC"];

    // ===== PHASE 5 =====
    anomd [label="detect_anomalies\nflag interval CV outliers,\nduplicates, out-of-order,\nany interval < 300 f (5 s),\nany interval > 1200 f (20 s)",
           fillcolor="#F2F2F2"];
    emit [label="OUTPUT\n*_segments.json:\nboundaries (21 ints)\nreference_quality, sa_coverage\nper-boundary method + confidence\nanomalies list\ninterval_mean/std/cv\nsegmenter_version, algorithm",
          shape=folder, fillcolor="#F2F2F2"];

    // ===== EDGES =====
    h5 -> refq;
    h5 -> sacov;

    refq -> clean [label="quality != bad"];
    refq -> fallb [label="quality == bad", style=dashed];
    sacov -> emit [style=dotted, label="reported only"];

    clean -> deriv -> cross -> retry;
    retry -> retry_lo [label="No"];
    retry -> score [label="Yes"];
    retry_lo -> score;
    score -> validate -> fallb;

    fallb -> peaks [label="Yes"];
    fallb -> fit [label="No, keep primary"];
    peaks -> fit;

    fit -> n0 [label="N=0"];
    fit -> n21 [label="N=21"];
    fit -> nclose [label="near 21"];
    fit -> grid [label="else"];
    nclose -> drop [label="N>21"];
    nclose -> fill [label="N<21"];
    fill -> projb21_old [label="Yes"];
    fill -> interp [label="No"];

    n0 -> phantom;
    n21 -> phantom;
    drop -> phantom;
    projb21_old -> phantom;
    interp -> phantom;
    grid -> phantom;

    phantom -> remove [label="pair matches"];
    remove -> phantom [label="iterate"];
    phantom -> endproj [label="no pair"];
    endproj -> projb1  [label="gap_to_start > 0.9*med"];
    endproj -> projb21 [label="gap_to_end > 0.9*med"];
    projb1  -> endproj [label="iterate", style=dashed];
    projb21 -> endproj [label="iterate", style=dashed];

    endproj -> anomd [label="done"];
    anomd -> emit;
}
